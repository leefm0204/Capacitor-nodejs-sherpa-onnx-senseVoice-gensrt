{
  "name": "com.sensevoicegensrtnode.app",
  "version": "1.0.0",
  "description": "SenseVoice SRT Generator with embeded Nodejs server in android phone",
  "type": "module",
  "main": "index.js",
  "keywords": [
    "capacitor",
    "mobile",
    "sherpa-onnx"
  ],
  "scripts": {
    "husky": "npm i && cd static/nodejs && npm i && cd ../../node-addon-api && npm i",
